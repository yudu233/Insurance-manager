/* app.wxss 全局样式 */
page {
  background: #f7f8fa;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, Segoe UI, Arial, sans-serif;
  color: #1f1f1f;
  font-size: 28rpx;
}

.container {
  padding: 32rpx;
  box-sizing: border-box;
}

.btn-primary {
  background: #07c160;
  color: #fff;
  border-radius: 12rpx;
  padding: 20rpx 40rpx;
  font-size: 32rpx;
}
