.auth-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 60rpx 60rpx;
  box-sizing: border-box;
  background: #fff;
}

.logo-placeholder {
  width: 160rpx;
  height: 160rpx;
  border-radius: 32rpx;
  background: linear-gradient(135deg, #07c160, #1aad19);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 600;
  font-size: 28rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 600;
  margin-top: 40rpx;
}

.desc {
  font-size: 26rpx;
  color: #888;
  margin-top: 20rpx;
  text-align: center;
}

.btn {
  width: 100%;
  margin-top: 80rpx;
}

.tips {
  font-size: 22rpx;
  color: #aaa;
  margin-top: 40rpx;
}
